            "by": "xpath",
            "value": "//input[@placeholder='Re-enter password']"
          },
          {
            "by": "id",
            "value": "confirm_password"
          }
        ]
      },
      "terms": {
        "primary": {
          "by": "id",
          "value": "termsCheckbox_v2"
