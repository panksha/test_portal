            "value": "//button[contains(text(),'Create Account')]"
          },
          {
            "by": "id",
            "value": "register-btn"
          }
        ]
      },
      "form_error": {
        "primary": {
          "by": "id",
          "value": "form-error-global"
        },
        "fallbacks": [
          {
            "by": "css",
            "value": ".form-error-global"
          },
          {
            "by": "xpath",
            "value": "//*[contains(@class,'form-error')]"
          }
        ]
      },
      "form_success": {
        "primary": {
          "by": "id",
          "value": "form-success"
        },
        "fallbacks": [
          {
            "by": "css",
            "value": ".form-success"
          },
          {
            "by": "xpath",
            "value": "//*[contains(@class,'form-success')]"
          }
        ]
      }
    },
    "forgot_password": {
      "email": {
        "primary": {
          "by": "id",
          "value": "reset-email"
        },
        "fallbacks": [
          {
            "by": "id",
            "value": "resetEmail_v2"
          },
          {
            "by": "css",
            "value": "input[type='email']"
          },
          {
            "by": "xpath",
            "value": "//input[@placeholder='Enter your registered email']"
          },
          {
            "by": "css",
            "value": "input[name='email']"
          }
        ]
      },
      "send_btn": {
        "primary": {
          "by": "id",
          "value": "send-reset-btn"
        },
        "fallbacks": [
          {
            "by": "id",
            "value": "sendResetBtn_v2"
          },
          {
            "by": "css",
            "value": "button[type='submit']"
          },
          {
            "by": "xpath",
            "value": "//button[contains(text(),'Send Reset Link')]"
          }
        ]
      },
      "success_msg": {
        "primary": {
          "by": "id",
          "value": "forgot-success-msg"
        },
        "fallbacks": [
          {
            "by": "css",
            "value": ".form-success"
          },
          {
            "by": "xpath",
            "value": "//*[contains(@class,'form-success')]"
          }
        ]
      },
      "error_msg": {
        "primary": {
          "by": "id",
          "value": "form-error-global"
        },
        "fallbacks": [
          {
            "by": "css",
            "value": ".form-error-global"
          },
          {
            "by": "xpath",
            "value": "//*[contains(@class,'form-error')]"
          }
        ]
      },
      "back_to_login": {
        "primary": {
          "by": "id",
          "value": "back-to-login-link"
        },
        "fallbacks": [
          {
            "by": "link_text",
            "value": "Back to Login"
          },
          {
            "by": "css",
            "value": "a[href='/']"
          },
          {
            "by": "xpath",
            "value": "//a[contains(text(),'Back to Login')]"
          }
        ]
      }
    }
  },
