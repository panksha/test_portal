{
  "base_url": "http://localhost:5000",
  "dashboard_port": 8000,
  "browser": "chrome",
  "headless": false,
  "implicit_wait": 0,
  "explicit_wait": 10,
  "screenshot_on_failure": true,
  "reports_dir": "qa_framework/reports",
  "healing_log": "qa_framework/reports/healing_log.json",
  "locators": {
    "registration": {
      "first_name": {
        "primary": {
          "by": "id",
          "value": "firstName_v2"
        },
        "fallbacks": [
          {
            "by": "id",
            "value": "firstName_v2"
          },
          {
            "by": "css",
            "value": "input[name='first_name']"
          },
          {
            "by": "xpath",
            "value": "//input[@placeholder='Enter first name']"
          },
          {
            "by": "xpath",
            "value": "//label[contains(text(),'First Name')]/following-sibling::input"
          },
          {
            "by": "id",
            "value": "first_name"
          }
        ]
      },
      "last_name": {
        "primary": {
          "by": "id",
          "value": "lastName_v2"
        },
        "fallbacks": [
          {
            "by": "id",
            "value": "lastName_v2"
          },
          {
            "by": "css",
