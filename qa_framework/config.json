          {
            "by": "css",
            "value": "input[type='email']"
          },
          {
            "by": "xpath",
            "value": "//input[@placeholder='Enter your email']"
          },
          {
            "by": "css",
            "value": "input[name='email']"
          },
          {
            "by": "id",
            "value": "email"
          }
        ]
      },
      "password": {
        "primary": {
          "by": "id",
          "value": "userPassword_v2"
        },
        "fallbacks": [
          {
