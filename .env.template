# ==============================================================================
# Jira Cloud Integration Configuration Template
# ==============================================================================
# Copy this file to a new file named '.env' in the same folder, and fill in
# your Jira Cloud API credentials.
#
# IMPORTANT: Never commit your actual '.env' file containing secrets to git!
# ==============================================================================

# Your Jira Cloud base URL (e.g., https://your-domain.atlassian.net)
JIRA_BASE_URL=https://yourorg.atlassian.net

# Your Atlassian Cloud user email address (e.g., alex@company.com)
JIRA_USER_EMAIL=yourname@example.com

# Your secure Atlassian API Token
# Generate one here: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_secure_api_token_here

# The target Jira Project Key (e.g., QA, BUGS, KAN)
JIRA_PROJECT_KEY=QA
